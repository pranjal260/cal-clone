# Database Configuration
# For Supabase: Get from Settings > Database > Connection String > PostgreSQL
# For Neon: Get from Dashboard > Connection String
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Direct database URL (for Prisma)
# Usually same as DATABASE_URL, used when migrations need direct connection
DIRECT_URL="postgresql://user:password@host:port/dbname"

# Server port
PORT=5000

# CORS Configuration (uncomment and modify for production)
# CORS_ORIGIN="https://your-frontend-domain.vercel.app"
